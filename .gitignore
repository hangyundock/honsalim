# 혼살림 .gitignore
# 출처: POLICY §10-3 + I1 (보안 다중 방어) + ARCH §3 + DECISIONS H2 [확정]
# 작성: 2026-05-27 세션 #2

# =====================================================
# secrets — 절대 추적 금지 (DECISIONS H2)
# =====================================================
# (D:\secrets\affiliate_hub\는 본 저장소 외부지만 안전 차원)
*.env
*.env.*
.env
.env.*
**/secrets/**
**/credentials/**

# =====================================================
# 데이터·로그·빌드 산출물 (ARCH §3)
# =====================================================
data/
!data/.gitkeep
build/
logs/

# 단, manifest.json은 추적 (POLICY §10-3, 빌드 일관성)
!data/manifest.json

# =====================================================
# Python
# =====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
*.pickle
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 가상환경 (본 프로젝트 미사용이지만 안전 차원)
venv/
.venv/
env/
.env/

# =====================================================
# IDE·OS
# =====================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# Cloudflare·Wrangler
# =====================================================
.wrangler/
wrangler.toml.local
.dev.vars

# =====================================================
# SQLite 임시 파일 (WAL 모드, DB.md §15-1)
# =====================================================
# data/ 폴더 자체가 이미 제외되지만 안전 차원 명시적 추가 (세션 #3 검토)
*-journal
*-shm
*-wal
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# =====================================================
# 임시 파일
# =====================================================
*.tmp
*.bak
*.log
*.cache
