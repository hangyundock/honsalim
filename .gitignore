# 혼살림 .gitignore
# 출처: POLICY §10-3 + I1 (보안 다중 방어) + ARCH §3 + DECISIONS H2 [확정]
# 작성: 2026-05-27 세션 #2

# =====================================================
# secrets — 절대 추적 금지 (DECISIONS H2)
# =====================================================
# (D:\secrets\affiliate_hub\는 본 저장소 외부지만 안전 차원)
*.env
*.env.*
.env
.env.*
**/secrets/**
**/credentials/**

# =====================================================
# 데이터·로그·빌드 산출물 (ARCH §3)
# =====================================================
data/
!data/.gitkeep
# build/ 내부는 제외하되, 배포용 정적 산출물(build/site = 공개 HTML)만 커밋 허용
# (방법 A 무인 자동 배포 — push 시 GitHub Actions가 build/site를 Cloudflare Pages에 업로드).
# DB·draft 등 비공개 데이터는 data/에 있어 그대로 제외됨.
build/*
!build/site/
logs/

# 로컬 빌드 프리뷰 설정 (preview_start용 — build/site 정적 서버, 로컬 전용)
.claude/launch.json

# 단, manifest.json은 추적 (POLICY §10-3, 빌드 일관성)
!data/manifest.json

# =====================================================
# Python
# =====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
*.pickle
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 가상환경 (본 프로젝트 미사용이지만 안전 차원)
venv/
.venv/
env/
.env/

# =====================================================
# IDE·OS
# =====================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# Cloudflare·Wrangler
# =====================================================
.wrangler/
wrangler.toml.local
.dev.vars

# =====================================================
# SQLite 임시 파일 (WAL 모드, DB.md §15-1)
# =====================================================
# data/ 폴더 자체가 이미 제외되지만 안전 차원 명시적 추가 (세션 #3 검토)
*-journal
*-shm
*-wal
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# =====================================================
# 임시 파일
# =====================================================
*.tmp
*.bak
*.log
*.cache

# 진단·스크래치 스크립트 — 커밋 사고 방지 (세션 #12, 재발 방지 근본 조치)
# 세션 #15: tmp_*.py → tmp_* 로 확대 (라이브 스모크 결과 .txt 등 모든 임시 산출물 차단)
tmp_*
scratch_*.py
*_scratch.py

# =====================================================
# Claude Design 핸드오프 원본 (대용량 ~9.7MB) — 기록 CHOICE.md만 추적
# =====================================================
docs/design_drafts/honsalim/
docs/design_drafts/*.tar.gz
